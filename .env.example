# =============================================================
#  laraseo — environment configuration
#  Copy to .env, then run: php artisan key:generate
# =============================================================

# --- Application ---
APP_NAME=laraseo
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Public base URL. Used for canonical URLs, sitemap, and OG tags — set this in production.
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# --- Logging ---
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database (MySQL 8+ or SQLite) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel_seo_starter
DB_USERNAME=root
DB_PASSWORD=

# --- Session ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# --- Broadcast / Filesystem / Queue ---
BROADCAST_CONNECTION=log
# Media library + featured images are served from the "public" disk.
# Run `php artisan storage:link` once after setup.
FILESYSTEM_DISK=public
# Sitemap regeneration runs on the queue (NFR-01). Run a worker: `php artisan queue:work`.
QUEUE_CONNECTION=database

# --- Cache ---
CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail (password reset emails) ---
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- AWS / S3 (optional remote media storage) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Admin seeder (php artisan db:seed) ---
# Default admin account created by DatabaseSeeder (FR-05). CHANGE THESE before deploying.
SEED_ADMIN_NAME="Admin"
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="password"

# --- Frontend (Vite) ---
VITE_APP_NAME="${APP_NAME}"
